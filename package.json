{
  "name": "bbaekkom-index",
  "version": "1.0.5",
  "description": "빼꼼 인덱스 - 모니터 가장자리에 빼꼼 튀어나오는 디지털 메모 인덱스",
  "main": "main.js",
  "author": "made in people",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build": "electron-builder -mw --publish never"
  },
  "build": {
    "appId": "com.madeinpeople.bbaekkom",
    "productName": "빼꼼 인덱스",
    "copyright": "Copyright © 2026 made in people",
    "afterPack": "build/after-pack.js",
    "publish": [
      { "provider": "github", "owner": "develop-likekorean", "repo": "-", "releaseType": "release" }
    ],
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "icon.png",
      "icon.ico",
      "icon.icns"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "identity": null
    },
    "dmg": {
      "title": "빼꼼 인덱스 설치",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis" }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "빼꼼 인덱스 v1.0.5"
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
